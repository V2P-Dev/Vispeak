{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "opener:default",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "process:default"
  ]
}
