{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vispeak",
  "version": "0.1.1",
  "identifier": "app.vispeak",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vispeak",
        "width": 900,
        "height": 600,
        "label": "main",
        "visible": false
      },
      {
        "label": "overlay",
        "width": 400,
        "height": 160,
        "transparent": true,
        "shadow": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "publisher": "V2P | Vladimir Puchnin",
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBRDE4NkY3NENCRDA3NDAKUldSQUI3MU05NGJST2loemU2UDZ4NTRLWVpWbUF1bzhrdlpOcC9XMGphc1N6ck9hbStFUUkzTGoK",
      "endpoints": [
        "https://github.com/V2P-Dev/Vispeak/releases/latest/download/latest.json"
      ]
    }
  }
}
